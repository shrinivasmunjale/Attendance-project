APP_NAME="Student Attendance System"
DEBUG=false

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite:///./attendance.db

# JWT — change this to a long random string in production
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# YOLO model path
YOLO_MODEL_PATH=models_weights/yolov8n.pt
YOLO_CONFIDENCE=0.5

# Face recognition
FACE_DB_PATH=data/student_faces
FACE_RECOGNITION_THRESHOLD=0.6

# Camera: 0 = webcam, or rtsp://user:pass@ip:port/stream for CCTV
CAMERA_SOURCE=0
